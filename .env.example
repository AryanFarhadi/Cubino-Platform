# Database
DATABASE_URL=postgresql://cubino:cubino@localhost:5432/cubino

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# MinIO (Phase 2 uploads)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=cubino
MINIO_SECRET_KEY=cubino12345
MINIO_BUCKET=cubino-uploads

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Web (leave empty in production — browser uses same origin via nginx)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_APP_URL=https://cubino.ir
